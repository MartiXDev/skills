{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/schemas/ai-repository-bootstrap-manifest.schema.json",
  "title": "AI repository bootstrap template manifest",
  "type": "object",
  "required": ["schemaVersion", "profileLayers", "technologyLayers", "combinationLayers"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "profileLayers": {
      "type": "object",
      "required": ["Minimal", "Standard", "Full"],
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": { "$ref": "#/$defs/layer" }
      }
    },
    "technologyLayers": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "#/$defs/namedLayer" }
        ]
      }
    },
    "combinationLayers": {
      "type": "array",
      "items": {
        "allOf": [
          { "$ref": "#/$defs/namedLayer" },
          {
            "type": "object",
            "required": ["technologies", "match"],
            "properties": {
              "technologies": {
                "type": "array",
                "minItems": 2,
                "uniqueItems": true,
                "items": { "type": "string", "minLength": 1 }
              },
              "match": { "enum": ["Exact", "All"] }
            }
          }
        ]
      }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "layer": {
      "type": "object",
      "required": ["path", "priority"],
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "priority": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "namedLayer": {
      "type": "object",
      "required": ["name", "description", "path", "priority"],
      "properties": {
        "name": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" },
        "description": { "type": "string", "minLength": 1 },
        "path": { "type": "string", "minLength": 1 },
        "priority": { "type": "integer" }
      }
    }
  }
}

